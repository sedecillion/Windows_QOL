<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="settings_UI.Views.ScreenShotToolPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:settings_UI.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="30,0,30,0">

        <StackPanel>
            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" 
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                BorderThickness="1" CornerRadius="8" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Enable Screenshot Tool" 
                           VerticalAlignment="Center" 
                           FontSize="16" 
                           FontWeight="SemiBold" />
                        
                        <TextBlock Text="Capture screenshot, quickly Rename, Save or Delete in one go" 
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                    </StackPanel>

                    <ToggleSwitch IsOn="{x:Bind SC_ToolViewModel.IsEnabled, Mode=TwoWay}" 
                      Grid.Column="1" 
                      Margin="0" 
                      MinWidth="0" 
                      OnContent="{x:Null}" 
                      OffContent="{x:Null}"/>
                </Grid>
            </Border>

            <Grid Background="{ThemeResource CardBackgroundFillColorDefault}"
                  CornerRadius="8" Padding="20,10,10,10" Margin="0,12,0,0" RowSpacing="20">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <StackPanel HorizontalAlignment="Left" MinWidth="100" Spacing="5">
                    <TextBlock Text="Trigger Key: " FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <Button Padding="12,8"
                            BorderThickness="2" CornerRadius="10" Background="Transparent"
                            BorderBrush="{ThemeResource ControlElevationBorderBrush}"
                            Click="SC_ToolTriggerKeyPicker_Click"
                            HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                                <FontIcon Glyph="&#xE765;" FontSize="16" />
                                <TextBlock Text="{x:Bind SC_ToolViewModel.DisplayTriggerKey, Mode=OneWay}" 
                                    FontWeight="Bold" 
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Content="Use PrtScr" FontWeight="SemiBold" Click="TriggerKeyChangePrintScreen_Click"/>

                    </StackPanel>

                </StackPanel>
                <Grid ColumnSpacing="10" Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Header="Path to save screenshot" Text="{x:Bind SC_ToolViewModel.Target_Dir, Mode=TwoWay}"/>
                    <Button VerticalAlignment="Bottom" Grid.Column="1" Click="SCToolPickFolder">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <FontIcon Glyph="&#xE8DA;"/>
                            <TextBlock Text="Pick Folder"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <MenuFlyoutSeparator Grid.Row="2"/>
                
                <StackPanel Grid.Row="3" Spacing="12" Margin="0,0,0,10" Padding="0,0,0,10">
                    <TextBlock Text="Capture Behavior" FontWeight="SemiBold" />

                    <StackPanel Spacing="16">
                        <!-- Option 1: Snipping Tool Flow -->
                        <StackPanel Spacing="4">
                            <RadioButton Content="Interactive Mode (Region &amp; Full Screen)" 
                                GroupName="ScreenshotMode" 
                                IsChecked="{x:Bind SC_ToolViewModel.IsInteractiveMode, Mode=TwoWay}"
                                />
                            <TextBlock Text="Opens the Windows Snipping Tool Overlay for partial captures. Press ENTER to capture fullscreen instantly. "
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                FontSize="14" 
                                TextWrapping="Wrap" 
                                Margin="32,0,0,0" />
                            <TextBlock Text="Relies on the Win+Shift+S shortcut triggering snipping tool. You might want to turn off notifications for snipping tool"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                FontSize="14" 
                                TextWrapping="Wrap" 
                                Margin="32,0,0,0" />
                        </StackPanel>

                        <!-- Option 2: Full Screen Flow -->
                        <StackPanel Spacing="4">
                            <RadioButton Content="Basic Mode (Full Screen Only)" 
                                GroupName="ScreenshotMode" 
                                IsChecked="{x:Bind SC_ToolViewModel.IsBasicMode, Mode=TwoWay}"/>
                            <TextBlock Text="Instantly captures the entire screen in one go."
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                FontSize="14" 
                                TextWrapping="Wrap" 
                                Margin="32,0,0,0" />
                            <TextBlock Text="Standalone, and no requirement of Snipping tool or Win+Shift+S."
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                FontSize="14" 
                                TextWrapping="Wrap" 
                                Margin="32,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
