<UserControl
    x:Class="settings_UI.Views.TopBarControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20,0,20,0" VerticalAlignment="Top">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1.5*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <Button x:Name="ProfileSwitcherButton" 
                Grid.Column="0"
                HorizontalAlignment="Left" 
                HorizontalContentAlignment="Stretch"
                Padding="22,1,60,1" BorderThickness="2"
                CornerRadius="9" Height="65"
                Background="Transparent"
                Click="ProfileSwitcherButton_Click">

            <StackPanel Spacing="0" HorizontalAlignment="Left" VerticalAlignment="Center">
                <!-- Profile Name -->
                <TextBlock Text="{x:Bind MainViewModel.DisplayedProfileName, Mode=OneWay}" 
                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                           FontSize="16"
                           TextTrimming="CharacterEllipsis"/>

                <!-- Activate / Status Indicator -->
                <HyperlinkButton x:Name="ActivateProfileButton"
                                 Content="{x:Bind MainViewModel.DisplayedProfileActivateOrActivated, Mode=OneWay}"
                                 IsEnabled="{x:Bind MainViewModel.IsDisplayedProfileNotActiveProfile, Mode=OneWay}"
                                 Visibility="{x:Bind MainViewModel.ActivateButtonVisibility, Mode=OneWay}"
                                 Click="ActivateProfileButton_Click"
                                 Padding="0" 
                                 MinHeight="0"
                                 HorizontalAlignment="Left" />
            </StackPanel>
        </Button>

        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24">

            <Button x:Name="ToggleServiceButton" 
                    Background="Transparent" 
                    BorderThickness="2" 
                    BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                    CornerRadius="16"
                    Padding="16,8,16,8"
                    Click="ToggleServiceButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="{x:Bind MainViewModel.ServiceToggleIcon, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                    <TextBlock Text="{x:Bind MainViewModel.ServiceToggleText, Mode=OneWay}" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>

            <CheckBox x:Name="StartupCheckBox" 
                      Content="Run on Startup" 
                      IsChecked="{x:Bind MainViewModel.RunOnStartup, Mode=OneWay}"
                      Checked="StartupCheckBox_Changed"
                      Unchecked="StartupCheckBox_Changed"
                      Margin="0" 
                      VerticalAlignment="Center"/>
        </StackPanel>

        <Button x:Name="MasterSaveButton" 
                Grid.Column="2"
                Content="Save Changes" 
                Height="36" 
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Click="MasterSaveButton_Click" />
    </Grid>
</UserControl>