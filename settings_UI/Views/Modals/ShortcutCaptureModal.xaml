<Window
    x:Class="settings_UI.Views.Modals.ShortcutCaptureModal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Shortcut Capture">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base"/>
    </Window.SystemBackdrop>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border x:Name="ModalTitleBar" Grid.Row="0"
                Background="{ThemeResource SolidBackgroundFillColorSecondaryBrush}"
                BorderThickness="0,0,0,1" BorderBrush="{ThemeResource AccentControlElevationBorderBrush}">
            <Grid Height="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="140" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Capture Input" VerticalAlignment="Center" Margin="16,0,0,0" FontSize="12" Style="{StaticResource CaptionTextBlockStyle}"/>
            </Grid>
        </Border>

        <!-- Main Content (Wide Layout) -->
        <Grid Grid.Row="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <SelectorBar x:Name="InputSelector" SelectionChanged="InputSelector_SelectionChanged">
                <SelectorBarItem x:Name="KeyboardTab" Text="Keyboard" />
                <SelectorBarItem x:Name="MouseTab" Text="Mouse" />
            </SelectorBar>

            <!-- Keyboard Capture View -->
            <StackPanel x:Name="KeyboardPanel" Grid.Row="1" Spacing="20" Margin="0,24,0,0">
                <Border x:Name="KeyboardCaptureBorder"
                        Height="140" CornerRadius="8"
                        Background="{ThemeResource SmokeFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource SystemControlHighlightAccentBrush}"
                        BorderThickness="2" IsTabStop="True" KeyDown="KeyboardCaptureBorder_KeyDown">
                    <Grid VerticalAlignment="Center" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="KeyboardShortcutText" Text="No keys Captured..." HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" />
                        <TextBlock Grid.Row="1" Text="{x:Bind _keyboardInputHint}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" />
                    </Grid>
                </Border>
                <ToggleButton x:Name="KeyboardRecordBtn" Content="Start Recording" HorizontalAlignment="Center" Width="150" Checked="RecordBtn_Checked" Unchecked="RecordBtn_Unchecked"/>
            </StackPanel>

            <!-- Mouse Capture View -->
            <StackPanel x:Name="MousePanel" Grid.Row="1" Spacing="20" Margin="0,24,0,0" Visibility="Collapsed">
                <Border x:Name="MouseCaptureBorder"
                        Height="140" CornerRadius="8"
                        Background="{ThemeResource SmokeFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource SystemControlHighlightAccentBrush}"
                        BorderThickness="2" 
                        PointerPressed="MouseCaptureBorder_PointerPressed"
                        PointerWheelChanged="MouseCaptureBorder_PointerWheelChanged">
                    <TextBlock x:Name="MouseShortcutText" Text="No input Captured..." HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" />
                </Border>
                <ToggleButton x:Name="MouseRecordBtn" Content="Start Recording" HorizontalAlignment="Center" Width="150" Checked="RecordBtn_Checked" Unchecked="RecordBtn_Unchecked"/>
            </StackPanel>
        </Grid>

        <!-- Bottom Action Row -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="24,0,24,24">
            <Button Content="OK" Style="{StaticResource AccentButtonStyle}" Width="100" Click="OKButton_Click" />
            <Button Content="Cancel" Width="100" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>