<Window
    x:Class="settings_UI.Views.Modals.SelectWindowModal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:settings_UI.Helpers"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid x:Name="ModalTitleBar" Height="48" Background="Transparent" VerticalAlignment="Top">
            <TextBlock Text="Pick a Window" VerticalAlignment="Center" Margin="16,0,0,0" Style="{StaticResource BodyTextBlockStyle}" FontWeight="SemiBold"/>
        </Grid>

        <ListView x:Name="WindowsListView"
                  Grid.Row="1" SelectionMode="Single" Margin="16,8,16,8" CornerRadius="5"
                  Background="{ThemeResource CardBackgroundFillColorDefault}"
                  DoubleTapped="WindowsListView_DoubleTapped">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="helpers:WindowItemUI">
                    <StackPanel Orientation="Vertical" Margin="0,10,0,10" Padding="0,6,0,6" >
                        <TextBlock Text="{x:Bind DisplayTitle}" 
                                   TextTrimming="CharacterEllipsis" 
                                   MaxLines="1" 
                                   FontSize="14"/>
                        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,2,0,0">
                            <TextBlock Text="{x:Bind ExeName}" 
                                       FontWeight="Bold" 
                                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                                       FontSize="12"/>
                            <TextBlock Text="{x:Bind FormattedAhkTarget}"
                                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                                       FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Padding="16" >
            <Button Content="Select" Style="{StaticResource AccentButtonStyle}" Width="80" Click="SelectButton_Click"/>
            <Button Content="Cancel" Width="80" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>