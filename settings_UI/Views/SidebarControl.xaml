<UserControl
    x:Class="settings_UI.Views.SidebarControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:settings_UI.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" 
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
            >
        <Grid>
            <ListView ItemsSource="{x:Bind MainViewModel.SidebarItems}" 
                      SelectedItem="{x:Bind MainViewModel.SelectedSettingCategory, Mode=TwoWay}"
                      Margin="0,0,0,0">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:NavigationItem">
                        <StackPanel Orientation="Horizontal" Padding="10,8" Spacing="15" VerticalAlignment="Center">
                            <FontIcon Glyph="{x:Bind IconGlyph}" 
                                      FontFamily="{StaticResource SymbolThemeFontFamily}" 
                                      FontSize="16" 
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind Title}" 
                                       FontSize="14" 
                                       VerticalAlignment="Center" 
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            
            <Grid VerticalAlignment="Bottom" Margin="10,10,10,10" CornerRadius="10" Padding="10" ColumnSpacing="10"
                        Background="{ThemeResource CardBackgroundFillColorDefault}">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <HyperlinkButton Grid.ColumnSpan="2" HorizontalAlignment="Center" NavigateUri="https://github.com/sedecillion/Windows_QOL/releases/" >
                    <StackPanel Orientation="Horizontal" Spacing="5"> 
                        <FontIcon Glyph="&#xE71B;" FontSize="14" />
                        <TextBlock Text="View Latest Release" FontSize="14" />
                    </StackPanel>
                </HyperlinkButton>
                <HyperlinkButton Grid.Row="2" NavigateUri="https://github.com/sedecillion/Windows_QOL"
                                 ToolTipService.ToolTip="View Source"
                                 Padding="3">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <FontIcon Glyph="&#xE943;" FontSize="12"/>
                        <TextBlock Text="GitHub" FontSize="12"/>
                    </StackPanel>
                </HyperlinkButton>
                <TextBlock Text="App Version: v1.0.2.0" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center"
                           FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Grid>
        </Grid>
    </Border>
</UserControl>