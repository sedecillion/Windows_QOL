<Page
    x:Class="settings_UI.Views.RedactedPastePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:settings_UI.Models"
    mc:Ignorable="d">

    <ScrollViewer Padding="30,0,30,30">
        <StackPanel HorizontalAlignment="Stretch" Spacing="3">

            <!-- Master Toggle Card -->
            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" 
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                    BorderThickness="1" CornerRadius="8" Margin="0,0,0,20" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Enable Redacted Paste" 
                                   VerticalAlignment="Center" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Replace or remove desired text when pasting" 
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                    </StackPanel>

                    <ToggleSwitch IsOn="{x:Bind ViewModel.IsEnabled, Mode=TwoWay}" 
                                  Grid.Column="1" 
                                  Margin="0" 
                                  MinWidth="0" 
                                  OnContent="{x:Null}" 
                                  OffContent="{x:Null}"/>
                </Grid>
            </Border>


            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" 
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                    BorderThickness="1" CornerRadius="8" Margin="0,0,0,20" Padding="16,12">
                <StackPanel HorizontalAlignment="Left" MinWidth="200" Spacing="5">
                    <TextBlock Text="Trigger Key: " FontWeight="SemiBold"/>
                    <Button Padding="12,8"
                        BorderThickness="2" CornerRadius="10" Background="Transparent"
                        BorderBrush="{ThemeResource ControlElevationBorderBrush}"
                        Click="RedactedPasteTriggerKeyPicker_Click"
                        HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                            <FontIcon Glyph="&#xE765;" FontSize="16" />
                            <TextBlock Text="{x:Bind ViewModel.DisplayTriggerKey, Mode=OneWay}" 
                                FontWeight="Bold" 
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                </StackPanel>
            </Border>

            <Button Click="AddReplacement_Click">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Add New Replacement"/>
                    <FontIcon Glyph="&#xE710;" FontSize="14"/>
                </StackPanel>
            </Button>

            <MenuFlyoutSeparator Margin="0,0,0,10" />

            <!-- Dynamic List of Replacements -->
            <ItemsControl ItemsSource="{x:Bind ViewModel.redactedPasteReplacements, Mode=OneWay}" HorizontalAlignment="Stretch">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:ReplacementEntryDto">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12"
                                HorizontalAlignment="Stretch">

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0" 
                                     Text="{x:Bind Dirty, Mode=TwoWay}"
                                     HorizontalAlignment="Stretch">
                                    <TextBox.HeaderTemplate>
                                        <DataTemplate>
                                            <ContentPresenter HorizontalAlignment="Stretch" 
                                                  HorizontalContentAlignment="Stretch">

                                                <TextBlock TextWrapping="Wrap" 
                                                    HorizontalAlignment="Stretch">
                                                        <Run Text="Target Text " />
                                                        <Run Text="(Use &lt;A_UserName&gt; for current OS username)" 
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                              FontSize="14" />
                                                </TextBlock>
                                            </ContentPresenter>
                                        </DataTemplate>
                                    </TextBox.HeaderTemplate>
                                </TextBox>

                                <TextBox Grid.Column="1" 
                                     Text="{x:Bind Clean, Mode=TwoWay}"
                                     HorizontalAlignment="Stretch">
                                    <TextBox.HeaderTemplate>
                                        <DataTemplate>
                                            <ContentPresenter HorizontalAlignment="Stretch" 
                                                HorizontalContentAlignment="Stretch">
                                                <TextBlock TextWrapping="Wrap" 
                                                   HorizontalAlignment="Stretch">
                                                    <Run Text="Replacement " />
                                                    <Run Text="(Leave blank to remove Target Text)" 
                                                         Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                </TextBlock>
                                            </ContentPresenter>
                                        </DataTemplate>
                                    </TextBox.HeaderTemplate>
                                </TextBox>


                                <Button Grid.Column="2" VerticalAlignment="Bottom" Margin="0,0,0,2" 
                                        Click="DeleteReplacement_Click" ToolTipService.ToolTip="Delete Replacement">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{ThemeResource SystemFillColorCriticalBackground}"/>
                                    </Button.Resources>
                                    <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                </Button>
                            </Grid>

                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</Page>